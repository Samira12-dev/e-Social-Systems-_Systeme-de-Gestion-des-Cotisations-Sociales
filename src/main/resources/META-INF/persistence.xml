<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="e_Social">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.example.demo1.Employeur</class>
        <class>com.example.demo1.Assure</class>
        <class>com.example.demo1.Declaration</class>
        <class>com.example.demo1.Cotisation</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3307/e_Social"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="Samira12"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>

    </persistence-unit>
</persistence>